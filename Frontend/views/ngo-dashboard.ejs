<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NGO Dashboard - MadadSetu</title>
    <link rel="icon" href="/uploads/MadadSetu_logo.png" type="image/png">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-green: #10b981;
            --primary-green-dark: #059669;
            --light-green: #d1fae5;
            --text-dark: #1f2937;
            --text-muted: #6b7280;
            --background: #f9fafb;
            --white: #ffffff;
            --border-color: #e5e7eb;
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background:
                radial-gradient(circle at top left, rgba(16, 185, 129, 0.18), transparent 35%),
                radial-gradient(circle at bottom right, rgba(20, 184, 166, 0.14), transparent 32%),
                var(--background);
            color: var(--text-dark);
            min-height: 100vh;
        }

        .page-shell {
            min-height: 100vh;
            display: grid;
            place-items: center;
            padding: 2rem 1rem;
        }

        .dashboard-card {
            width: min(820px, 100%);
            background: var(--white);
            border: 1px solid rgba(229, 231, 235, 0.9);
            border-radius: 1.5rem;
            box-shadow: var(--shadow-lg);
            padding: 2rem;
        }

        .hero {
            display: flex;
            justify-content: space-between;
            gap: 1.5rem;
            align-items: flex-start;
            flex-wrap: wrap;
            margin-bottom: 1.5rem;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 0.9rem;
            border-radius: 999px;
            background: var(--light-green);
            color: var(--primary-green-dark);
            font-weight: 700;
            font-size: 0.9rem;
        }

        h1 {
            margin: 0.9rem 0 0.4rem;
            font-size: clamp(1.8rem, 3vw, 2.4rem);
            letter-spacing: -0.04em;
        }

        .subtitle {
            margin: 0;
            color: var(--text-muted);
            font-size: 1rem;
        }

        .panel {
            border: 1px solid var(--border-color);
            border-radius: 1.25rem;
            padding: 1.25rem;
            background: linear-gradient(180deg, #fff, #f9fafb);
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 1rem;
            margin-top: 1rem;
        }

        .field {
            padding: 1rem;
            border-radius: 1rem;
            background: #fff;
            border: 1px solid var(--border-color);
        }

        .field-label {
            display: block;
            color: var(--text-muted);
            font-size: 0.85rem;
            margin-bottom: 0.35rem;
        }

        .field-value {
            font-size: 1rem;
            font-weight: 600;
            word-break: break-word;
        }

        .actions {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
            margin-top: 1.5rem;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0.85rem 1.2rem;
            border-radius: 0.85rem;
            text-decoration: none;
            font-weight: 700;
            transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary-green), var(--primary-green-dark));
            color: white;
            box-shadow: 0 12px 22px rgba(16, 185, 129, 0.22);
        }

        .btn-secondary {
            background: #fff;
            color: var(--text-dark);
            border: 1px solid var(--border-color);
        }

        .btn:hover {
            transform: translateY(-1px);
        }

        @media (max-width: 720px) {
            .dashboard-card {
                padding: 1.25rem;
                border-radius: 1.25rem;
            }

            .grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <main class="page-shell">
        <section class="dashboard-card">
            <div class="hero">
                <div>
                    <div class="badge">Logged In</div>
                    <h1>Welcome, <%= ngo.orgName %></h1>
                    <p class="subtitle">Your NGO account is authenticated and ready.</p>
                </div>
                <a class="btn btn-secondary" href="/ngo/profile">View Profile</a>
                <a class="btn btn-secondary" href="/ngo/logout">Log out</a>
            </div>

            <div class="panel">
                <div class="grid">
                    <div class="field">
                        <span class="field-label">Organization Name</span>
                        <div class="field-value"><%= ngo.orgName %></div>
                    </div>
                    <div class="field">
                        <span class="field-label">Email Address</span>
                        <div class="field-value"><%= ngo.email %></div>
                    </div>
                    <div class="field">
                        <span class="field-label">Phone Number</span>
                        <div class="field-value"><%= ngo.phone %></div>
                    </div>
                    <div class="field">
                        <span class="field-label">Organization Type</span>
                        <div class="field-value"><%= ngo.orgType %></div>
                    </div>
                    <div class="field">
                        <span class="field-label">Member Since</span>
                        <div class="field-value"><%= new Date(ngo.submittedAt).toLocaleString() %></div>
                    </div>
                    <div class="field">
                        <span class="field-label">Account Status</span>
                        <div class="field-value">Active</div>
                    </div>
                </div>

                <div class="actions">
                    <a class="btn btn-primary" href="/ngo/data">View Saved NGO Data</a>
                    <a class="btn btn-secondary" href="/get-started">Back to Options</a>
                </div>
            </div>
        </section>
    </main>
</body>
</html>
