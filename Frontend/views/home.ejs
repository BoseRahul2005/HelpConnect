<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MadadSetu - NGO Platform</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/home.css">
</head>
<body>
    <%
        const profileButton = loggedInNgo
            ? {
                href: '/ngo/profile',
                label: `Open NGO profile for ${loggedInNgo.orgName}`,
                title: loggedInNgo.orgName,
                text: ngoInitials,
            }
            : loggedInUser
                ? {
                    href: '/profile',
                    label: `Open profile for ${loggedInUser.name}`,
                    title: loggedInUser.name,
                    text: userInitials,
                    pictureUrl: loggedInUser.profilePictureUrl,
                }
                : null;
    %>
    <!-- Navigation Bar -->
    <nav class="navbar">
        <div class="nav-container">
            <!-- Logo -->
            <div class="nav-logo">
                <svg class="logo-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 2C6.48 2 2 6.48 2 12C2 16.42 5.04 20.07 9 21.5C9 21.5 10 19.5 12 19.5C14 19.5 15 21.5 15 21.5C18.96 20.07 22 16.42 22 12C22 6.48 17.52 2 12 2Z" fill="#2E7D32"/>
                    <path d="M12 5C13.66 5 15 6.34 15 8C15 9.66 13.66 11 12 11C10.34 11 9 9.66 9 8C9 6.34 10.34 5 12 5Z" fill="white"/>
                </svg>
                <span class="logo-text">MadadSetu</span>
            </div>

            <!-- Search Bar (Hidden on mobile) -->
            <div class="nav-search">
                <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"></circle>
                    <path d="m21 21-4.35-4.35"></path>
                </svg>
                <input 
                    type="text" 
                    class="search-input" 
                    placeholder="Search NGOs, causes, or posts"
                    aria-label="Search NGOs, causes, or posts"
                >
            </div>

            <!-- Right Menu -->
            <div class="nav-menu">
                <!-- Notification Icon -->
                <button class="nav-icon-btn" aria-label="Notifications">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2E7D32" stroke-width="2">
                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                        <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                    </svg>
                    <span class="notification-badge">2</span>
                </button>

                <!-- Get Started Button / Profile Badge -->
                <% if (profileButton) { %>
                    <a href="<%= profileButton.href %>" class="btn btn-primary profile-badge" aria-label="<%= profileButton.label %>" title="<%= profileButton.title %>">
                        <% if (profileButton.pictureUrl) { %>
                            <img class="profile-badge-image" src="<%= profileButton.pictureUrl %>" alt="" aria-hidden="true">
                        <% } else { %>
                            <%= profileButton.text %>
                        <% } %>
                    </a>
                <% } else { %>
                    <a href="/get-started" class="btn btn-primary">Get Started</a>
                <% } %>

                <!-- Mobile Menu Toggle -->
                <button class="sidebar-toggle" aria-label="Toggle sidebar" style="display: none;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="3" y1="12" x2="21" y2="12"></line>
                        <line x1="3" y1="6" x2="21" y2="6"></line>
                        <line x1="3" y1="18" x2="21" y2="18"></line>
                    </svg>
                </button>

                <button class="mobile-menu-toggle" aria-label="Toggle menu" aria-expanded="false">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div class="mobile-menu">
            <div class="mobile-search">
                <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"></circle>
                    <path d="m21 21-4.35-4.35"></path>
                </svg>
                <input 
                    type="text" 
                    class="search-input" 
                    placeholder="Search NGOs, causes, or posts"
                    aria-label="Search NGOs, causes, or posts"
                >
            </div>
            <div class="mobile-menu-content">
                <button class="nav-icon-btn" aria-label="Notifications">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2E7D32" stroke-width="2">
                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                        <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                    </svg>
                    <span class="notification-badge">2</span>
                </button>
                <% if (profileButton) { %>
                    <a href="<%= profileButton.href %>" class="btn btn-primary profile-badge" aria-label="<%= profileButton.label %>" title="<%= profileButton.title %>">
                        <% if (profileButton.pictureUrl) { %>
                            <img class="profile-badge-image" src="<%= profileButton.pictureUrl %>" alt="" aria-hidden="true">
                        <% } else { %>
                            <%= profileButton.text %>
                        <% } %>
                    </a>
                <% } else { %>
                    <a href="/get-started" class="btn btn-primary">Get Started</a>
                <% } %>
            </div>
        </div>
    </nav>

    <!-- Sidebar -->
    <aside class="sidebar">
        <!-- Main Navigation Section -->
        <div class="sidebar-section">
            <nav class="sidebar-nav">
                <!-- Home Link (Active) -->
                <a href="#" class="sidebar-link active">
                    <svg class="sidebar-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                        <polyline points="9 22 9 12 15 12 15 22"></polyline>
                    </svg>
                    <span>Home</span>
                </a>

                <!-- Popular NGOs Link -->
                <a href="#" class="sidebar-link">
                    <svg class="sidebar-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="23 6 13.5 15.5 8.5 10.5 1 17"></polyline>
                        <polyline points="17 6 23 6 23 12"></polyline>
                    </svg>
                    <span>Popular NGOs</span>
                </a>
            </nav>
        </div>

        <!-- Categories Section -->
        <div class="sidebar-section">
            <h3 class="sidebar-section-title">Categories</h3>
            <nav class="sidebar-nav">
                <!-- Education -->
                <a href="#" class="sidebar-link">
                    <svg class="sidebar-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                    </svg>
                    <span>Education</span>
                </a>

                <!-- Healthcare -->
                <a href="#" class="sidebar-link">
                    <svg class="sidebar-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                    </svg>
                    <span>Healthcare</span>
                </a>

                <!-- Disaster Relief -->
                <a href="#" class="sidebar-link">
                    <svg class="sidebar-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="2" y1="12" x2="22" y2="12"></line>
                        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                    </svg>
                    <span>Disaster Relief</span>
                </a>

                <!-- Animal Welfare -->
                <a href="#" class="sidebar-link">
                    <svg class="sidebar-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="6" cy="6" r="1.5" fill="currentColor"></circle>
                        <circle cx="18" cy="6" r="1.5" fill="currentColor"></circle>
                        <path d="M9 4c0-2 2-3 3-3s3 1 3 3"></path>
                        <path d="M12 10c-2 0-4 1-4 4v3c0 2 2 4 4 4s4-2 4-4v-3c0-3-2-4-4-4z"></path>
                        <circle cx="6" cy="17" r="1.5" fill="currentColor"></circle>
                        <circle cx="18" cy="17" r="1.5" fill="currentColor"></circle>
                    </svg>
                    <span>Animal Welfare</span>
                </a>
            </nav>
        </div>

        <!-- Support Section -->
        <div class="sidebar-section">
            <nav class="sidebar-nav">
                <!-- About -->
                <a href="#" class="sidebar-link">
                    <svg class="sidebar-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="12" y1="16" x2="12" y2="12"></line>
                        <line x1="12" y1="8" x2="12.01" y2="8"></line>
                    </svg>
                    <span>About</span>
                </a>

                <!-- Contact -->
                <a href="#" class="sidebar-link">
                    <svg class="sidebar-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                    </svg>
                    <span>Contact</span>
                </a>
            </nav>
        </div>

        <!-- Mobile Close Button -->
        <button class="sidebar-close" aria-label="Close sidebar">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </button>
    </aside>

    <!-- Main Content Wrapper -->
    <div class="content-wrapper">
        <!-- Main Feed Component -->
        <main class="feed-container">
            <!-- Feed Header -->
            <div class="feed-header">
                <h2 class="feed-title">Feed <span class="breadcrumb-separator">• Trending causes near you</span></h2>
            </div>

            <!-- Posts Feed -->
            <div class="posts-feed" id="postsFeed">
                <!-- Posts will be rendered here by JavaScript -->
            </div>
        </main>

        <!-- Right Sidebar Widgets -->
        <aside class="right-sidebar">
            <!-- Widget 1: Top NGOs -->
            <div class="widget widget-top-ngos">
                <div class="widget-header">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                    <h3 class="widget-title">Top NGOs</h3>
                </div>
                <div class="widget-content">
                    <ul class="ngo-list" id="ngoList">
                        <!-- NGO items will be rendered here by JavaScript -->
                    </ul>
                </div>
            </div>

            <!-- Widget 2: Urgent Cases -->
            <div class="widget widget-urgent-cases">
                <div class="widget-header">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3.05h16.94a2 2 0 0 0 1.71-3.05L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                        <line x1="12" y1="9" x2="12" y2="13"></line>
                        <line x1="12" y1="17" x2="12.01" y2="17"></line>
                    </svg>
                    <h3 class="widget-title urgent-cases-title">Urgent Cases</h3>
                </div>
                <div class="widget-content">
                    <ul class="urgent-cases-list" id="urgentCasesList">
                        <!-- Urgent cases will be rendered here by JavaScript -->
                    </ul>
                </div>
            </div>

            <!-- Widget 3: Call-to-Action Card -->
            <div class="widget widget-cta">
                <div class="cta-content">
                    <h3 class="cta-heading"><span class="cta-emoji">🌍 </span>Every donation counts</h3>
                    <p class="cta-subtext">Join 50,000+ donors making a difference worldwide.</p>
                </div>
                <button class="btn-start-giving">Start Giving</button>
            </div>
        </aside>
    </div>

    <script>
        window.__HOME_FEED_POSTS__ = <%- homeFeedPostsJson %>;
    </script>
    <script src="/home.js"></script>
</body>
</html>
