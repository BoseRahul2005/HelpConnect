<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Single User Log In - MadadSetu</title>
    <link rel="icon" href="/uploads/MadadSetu_logo.png" type="image/png">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/user-login.css">
</head>
<body>

    <!-- Main Content -->
    <main class="main-container">
        <div class="login-card">
            <!-- Header Icon -->
            <div class="card-header">
                <div class="icon-circle">
                    <svg class="header-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                    </svg>
                </div>
            </div>

            <!-- Form Title -->
            <div class="form-header">
                <h1 class="form-title">Welcome Back</h1>
                <p class="form-subtitle">Sign in to your account and make a difference</p>
            </div>

            <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
                <div class="form-alert error-message"><%= errorMessage %></div>
            <% } %>

            <!-- Login Form -->
            <form class="login-form" id="suLoginForm" method="POST" action="/user/login">
                <!-- Email or Mobile Number -->
                <div class="form-group">
                    <label for="emailOrMobile" class="form-label">Email or Mobile Number</label>
                    <div class="input-wrapper">
                        <span class="input-prefix">
                            <svg class="prefix-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="2" y="4" width="20" height="16" rx="2"/>
                                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                            </svg>
                        </span>
                        <input 
                            type="text" 
                            id="emailOrMobile" 
                            name="emailOrMobile" 
                            class="form-input" 
                            placeholder="you@example.com or +1234567890"
                            required
                        >
                    </div>
                    <span class="error-message" id="emailOrMobileError"></span>
                </div>

                <!-- Password -->
                <div class="form-group">
                    <div class="password-header">
                        <label for="password" class="form-label">Password</label>
                        <a href="#" class="forgot-password-link">Forgot?</a>
                    </div>
                    <div class="input-wrapper">
                        <input 
                            type="password" 
                            id="password" 
                            name="password" 
                            class="form-input" 
                            placeholder="Enter your password"
                            required
                        >
                        <button type="button" class="password-toggle" id="passwordToggle" aria-label="Toggle password visibility" aria-pressed="false">
                            <svg class="toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                        </button>
                    </div>
                    <span class="error-message" id="passwordError"></span>
                </div>

                <!-- Remember Me -->
                <div class="form-group checkbox-group">
                    <input 
                        type="checkbox" 
                        id="rememberMe" 
                        name="rememberMe" 
                        class="form-checkbox"
                    >
                    <label for="rememberMe" class="checkbox-label">
                        Keep me signed in
                    </label>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="btn-primary btn-submit">Sign In</button>
            </form>

            <!-- Footer Links -->
            <div class="form-footer">
                <p class="footer-text">
                    Don't have an account? <a href="/user/signup" class="footer-link">Sign Up</a>
                </p>
                <p class="footer-text">
                    <a href="/get-started" class="footer-link">← Back to Selection</a>
                </p>
            </div>
        </div>
    </main>
    <script src="/password-toggle.js"></script>
</body>
</html>
