<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NGO Log In - MadadSetu</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/ngo-login.css">
</head>
<body>
    <!-- Main Content -->
    <main class="main-container">
        <div class="login-card">
            <!-- Header Icon -->
            <div class="card-header">
                <div class="icon-circle">
                    <svg class="header-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 21h18M3 10h18M5 6h14M5 6V3h14v3M9 21v-8M15 21v-8M9 13h6v8H9z"/>
                    </svg>
                </div>
            </div>

            <!-- Form Title -->
            <div class="form-header">
                <h1 class="form-title">NGO Log In</h1>
                <p class="form-subtitle">Access your organization account</p>
            </div>

            <!-- Login Form -->
            <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
                <div class="form-alert error-message"><%= errorMessage %></div>
            <% } %>

            <form class="login-form" id="ngoLoginForm" method="POST" action="/ngo/login">
                <!-- Email or Mobile Number -->
                <div class="form-group">
                    <label for="emailOrMobile" class="form-label">Email or Mobile Number</label>
                    <input 
                        type="text" 
                        id="emailOrMobile" 
                        name="emailOrMobile" 
                        class="form-input" 
                        placeholder="your.email@organization.com or +1234567890"
                        required
                    >
                    <span class="error-message" id="emailOrMobileError"></span>
                </div>

                <!-- Password -->
                <div class="form-group">
                    <label for="password" class="form-label">Password</label>
                    <input 
                        type="password" 
                        id="password" 
                        name="password" 
                        class="form-input" 
                        placeholder="Enter your password"
                        required
                    >
                    <span class="error-message" id="passwordError"></span>
                </div>

                <!-- Remember Me -->
                <div class="form-group checkbox-group">
                    <input 
                        type="checkbox" 
                        id="rememberMe" 
                        name="rememberMe" 
                        class="form-checkbox"
                    >
                    <label for="rememberMe" class="checkbox-label">
                        Remember me
                    </label>
                </div>

                <!-- Forgot Password Link -->
                <div class="forgot-password-container">
                    <a href="#" class="forgot-password-link">Forgot your password?</a>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="btn-primary btn-submit">Log In to Your Account</button>
            </form>

            <!-- Footer Links -->
            <div class="form-footer">
                <p class="footer-text">
                    Don't have an account? <a href="/ngo/signup" class="footer-link">Sign Up</a>
                </p>
                <p class="footer-text">
                    <a href="/get-started" class="footer-link">← Back to Selection</a>
                </p>
            </div>
        </div>
    </main>
</body>
</html>
