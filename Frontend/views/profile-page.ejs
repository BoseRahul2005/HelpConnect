<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title><%= profileDisplayName %> Profile - MadadSetu</title>
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
	<link rel="stylesheet" href="/profile-page.css">
</head>
<body>
	<main class="profile-page-shell" data-profile-display-name="<%= profileDisplayName %>" data-profile-subtitle="<%= profileSubtitle %>" data-profile-picture-url="<%= profilePictureUrl || '' %>">
		<section class="profile-header">
			<button type="button" class="profile-avatar profile-avatar-button" data-profile-avatar-button aria-label="Change profile picture">
				<img class="profile-avatar-image" data-profile-avatar-image src="<%= profilePictureUrl || '' %>" alt="<%= profileDisplayName %> profile picture" <%= profilePictureUrl ? '' : 'hidden' %>>
				<span class="profile-avatar-placeholder" data-profile-avatar-placeholder <%= profilePictureUrl ? 'hidden' : '' %>>
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="12" cy="8.5" r="4.25"></circle>
						<path d="M4.5 20.5c1.6-4.4 5-6.6 7.5-6.6s5.9 2.2 7.5 6.6"></path>
					</svg>
				</span>
				<span class="profile-avatar-overlay">Change photo</span>
			</button>
			<input type="file" class="profile-picture-input" data-profile-picture-input accept="image/*" hidden>

			<div class="profile-identity">
				<h1 class="profile-display-name"><%= profileDisplayName %></h1>
				<p class="profile-secondary-name"><%= profileSubtitle %></p>
			</div>
		</section>

		<section class="profile-stats" aria-label="Profile summary">
			<% profileStats.forEach((stat) => { %>
				<article class="stat-card">
					<strong class="stat-value"><%= stat.value %></strong>
					<span class="stat-label"><%= stat.label %></span>
				</article>
			<% }) %>
		</section>

		<section class="profile-tabs" role="tablist" aria-label="Profile sections">
			<button class="profile-tab active" type="button" data-profile-tab="overview">Overview</button>
			<button class="profile-tab" type="button" data-profile-tab="posts">Posts</button>
			<button class="profile-tab" type="button" data-profile-tab="comments">Comments</button>
			<button class="profile-tab" type="button" data-profile-tab="donations">Donations</button>
			<button class="profile-tab" type="button" data-profile-tab="saved">Saved</button>
			<button class="profile-tab" type="button" data-profile-tab="history">History</button>
			<button class="profile-tab" type="button" data-profile-tab="upvoted">Upvoted</button>
		</section>

		<section class="profile-content">
			<article class="profile-panel active" data-profile-panel="overview">
				<div class="profile-card">
					<div class="profile-status-row">
						<div class="profile-status-label">
							<svg class="profile-status-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<circle cx="12" cy="12" r="9"></circle>
								<path d="M12 10v4"></path>
								<path d="M12 16h.01"></path>
							</svg>
							<span data-profile-status-label><%= profileStatusLabel %></span>
						</div>
						<span class="profile-status-chevron" aria-hidden="true">›</span>
					</div>

					<div class="profile-actions">
						<button type="button" class="profile-action profile-action-primary" data-create-post-button aria-expanded="false" aria-controls="postComposer">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M12 5v14"></path>
								<path d="M5 12h14"></path>
							</svg>
							<span>Create Post</span>
						</button>
						<button type="button" class="profile-action profile-action-icon" aria-label="Support">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M20 12c0 4.5-4.5 7.75-8 10-3.5-2.25-8-5.5-8-10a5 5 0 0 1 9-3 5 5 0 0 1 7 3Z"></path>
							</svg>
						</button>
					</div>

					<section class="profile-composer" id="postComposer" data-profile-composer hidden>
						<div class="composer-header">
							<div class="composer-author">
								<div class="composer-avatar" aria-hidden="true">
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
										<circle cx="12" cy="8.5" r="4.25"></circle>
										<path d="M4.5 20.5c1.6-4.4 5-6.6 7.5-6.6s5.9 2.2 7.5 6.6"></path>
									</svg>
								</div>
								<div class="composer-author-copy">
									<strong><%= profileDisplayName %></strong>
								</div>
							</div>
							<button type="button" class="composer-close" data-composer-close aria-label="Close post composer">×</button>
						</div>

						<form class="composer-form" data-composer-form>
							<input type="text" class="composer-field composer-title" name="title" placeholder="Title" maxlength="120" autocomplete="off">
							<textarea class="composer-field composer-body" name="body" placeholder="Share your story, cause, or thoughts..." rows="7" required></textarea>
							<input type="file" class="composer-image-input" data-composer-image-input name="image" accept="image/*" hidden>
							<div class="composer-image-preview" data-composer-image-preview hidden>
								<img class="composer-image-preview-img" data-composer-image-preview-img alt="Selected post image preview">
								<div class="composer-image-preview-copy">
									<strong>Image attached</strong>
									<span data-composer-image-name></span>
								</div>
								<button type="button" class="composer-image-remove" data-composer-image-remove aria-label="Remove selected image">×</button>
							</div>
							<div class="composer-fundraise-panel" data-composer-fundraise-panel hidden>
								<label class="composer-fundraise-label" for="fundRaiseGoal">Fundraise goal</label>
								<input type="number" class="composer-field composer-fundraise-input" id="fundRaiseGoal" name="fundRaiseGoal" min="1" step="1" placeholder="Enter goal amount">
								<p class="composer-fundraise-note">Adds a fundraiser badge and goal to this post.</p>
							</div>
							<div class="composer-emoji-picker" data-composer-emoji-picker hidden aria-label="Emoji picker"></div>
							<div class="composer-footer">
								<div class="composer-tools" aria-label="Post tools">
									<button type="button" class="composer-tool-button" data-composer-image-button aria-label="Add image">
										<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<rect x="3" y="4" width="18" height="16" rx="2"></rect>
											<circle cx="8.5" cy="9" r="1.5"></circle>
											<path d="m21 15-5-5L5 21"></path>
										</svg>
									</button>
									<button type="button" class="composer-tool-button" data-composer-fundraise-button aria-label="Fund raise">
										<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<circle cx="12" cy="12" r="9"></circle>
											<path d="M12 7v10"></path>
											<path d="M9 10.5c0-1.4 1.3-2.5 3-2.5s3 1.1 3 2.5S13.7 13 12 13s-3 1.1-3 2.5S10.3 18 12 18s3-1.1 3-2.5"></path>
										</svg>
									</button>
									<button type="button" class="composer-tool-button" data-composer-link-button aria-label="Add link">
										<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<path d="M10 13a5 5 0 0 1 0-7l1-1a5 5 0 0 1 7 7l-1 1"></path>
											<path d="M14 11a5 5 0 0 1 0 7l-1 1a5 5 0 0 1-7-7l1-1"></path>
										</svg>
									</button>
									<button type="button" class="composer-tool-button" data-composer-emoji-button aria-label="Add emoji">
										<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<circle cx="12" cy="12" r="9"></circle>
											<path d="M9 10h.01"></path>
											<path d="M15 10h.01"></path>
											<path d="M9 15c1 .8 2 .8 3 .8s2-.0 3-.8"></path>
										</svg>
									</button>
									<button type="button" class="composer-tool-button" data-composer-support-button aria-label="Support">
										<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<path d="M20 12c0 4.5-4.5 7.75-8 10-3.5-2.25-8-5.5-8-10a5 5 0 0 1 9-3 5 5 0 0 1 7 3Z"></path>
										</svg>
									</button>
								</div>

								<div class="composer-actions">
									<button type="button" class="composer-button composer-button-secondary" data-composer-cancel>Cancel</button>
									<button type="submit" class="composer-button composer-button-primary">Post</button>
								</div>
							</div>
						</form>
					</section>

					<div class="profile-empty-state" data-profile-empty-state>
						<div class="profile-empty-badge" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M12 21s-6.7-4.4-9-8.5C1 9.4 2.7 6.5 5.8 5.7c1.8-.5 3.8.1 5 1.5 1.2-1.4 3.2-2 5-1.5 3.1.8 4.8 3.7 2.8 6.8C18.7 16.6 12 21 12 21Z"></path>
							</svg>
						</div>
						<h2 data-profile-empty-title><%= profileEmptyTitle %></h2>
						<div class="profile-empty-copy" data-profile-empty-copy>
							<% profileEmptyCopy.forEach((line) => { %>
								<p><%= line %></p>
							<% }) %>
						</div>
					</div>
				</div>
			</article>

			<article class="profile-panel" data-profile-panel="posts">
				<div class="profile-posts-list" data-profile-posts-list>
					<% if (profilePosts.length) { %>
						<% profilePosts.forEach((post) => { %>
							<article class="profile-post-card" data-profile-post-card data-post-id="<%= post.id %>">
								<div class="profile-post-card-header">
									<div class="profile-post-author">
										<div class="profile-post-avatar" aria-hidden="true"><%= profileDisplayName.slice(0, 2).toUpperCase() %></div>
										<div class="profile-post-author-copy">
											<span class="profile-post-author-name"><%= profileDisplayName %></span>
											<span class="profile-post-author-subtitle"><%= profileSubtitle %></span>
										</div>
									</div>
									<div class="profile-post-card-meta">
										<span class="profile-post-time"><%= post.submittedAtLabel %></span>
										<button type="button" class="profile-post-delete" data-post-delete-button data-post-id="<%= post.id %>" aria-label="Delete post">
											<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
												<path d="M3 6h18"></path>
												<path d="M8 6V4h8v2"></path>
												<path d="M7 6h10l-1 12H8L7 6Z"></path>
												<path d="M10 11v5"></path>
												<path d="M14 11v5"></path>
											</svg>
										</button>
									</div>
								</div>
								<h3 class="profile-post-title"><%= post.title || 'New post' %></h3>
								<p class="profile-post-body"><%= post.body %></p>
											<% if (post.isFundraiser && post.fundRaiseGoalLabel) { %>
												<div class="profile-post-fundraiser">
													<span class="profile-post-badge profile-post-badge-fundraiser">Fundraiser</span>
													<span class="profile-post-goal">Goal: <%= post.fundRaiseGoalLabel %></span>
												</div>
											<% } %>
											<% if (post.imageUrl) { %>
												<div class="profile-post-media">
													<img class="profile-post-image" src="<%= post.imageUrl %>" alt="<%= post.imageName || post.title || 'Post image' %>">
												</div>
											<% } %>
							</article>
						<% }) %>
					<% } else { %>
						<div class="profile-card profile-placeholder-card profile-posts-empty" data-profile-posts-empty>
							<h2>Posts</h2>
							<p>Nothing to show here yet.</p>
						</div>
					<% } %>
				</div>
			</article>

			<article class="profile-panel" data-profile-panel="comments">
				<div class="profile-card profile-placeholder-card">
					<h2>Comments</h2>
					<p>No comments yet.</p>
				</div>
			</article>

			<article class="profile-panel" data-profile-panel="donations">
				<div class="profile-card profile-placeholder-card">
					<h2>Donations</h2>
					<p>No donations recorded yet.</p>
				</div>
			</article>

			<article class="profile-panel" data-profile-panel="saved">
				<div class="profile-card profile-placeholder-card">
					<h2>Saved</h2>
					<p>No saved items yet.</p>
				</div>
			</article>

			<article class="profile-panel" data-profile-panel="history">
				<div class="profile-card profile-placeholder-card">
					<h2>History</h2>
					<p>No activity history yet.</p>
				</div>
			</article>

			<article class="profile-panel" data-profile-panel="upvoted">
				<div class="profile-card profile-placeholder-card">
					<h2>Upvoted</h2>
					<p>No upvoted causes yet.</p>
				</div>
			</article>
		</section>
	</main>

	<script src="/profile-page.js"></script>
</body>
</html>
